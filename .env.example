# .env.example — Variables d'environnement pour Flashback Restore

# ============================================
# API Keys (OBLIGATOIRES)
# ============================================

# Google Gemini — Analyse et restauration d'images par IA
GEMINI_API_KEY=your-gemini-api-key-here

# D-ID — Animation faciale des photos restaurées
DID_API_KEY=your-did-api-key-here

# ============================================
# Base de données
# ============================================
DATABASE_URL=postgresql://flashback:flashback@localhost:5432/flashback

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Application
# ============================================
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=change-me-in-production

# ============================================
# URLs publiques
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
