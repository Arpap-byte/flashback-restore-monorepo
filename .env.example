# .env.example — Variables d'environnement pour Flashback Restore
# Copiez ce fichier en .env et remplissez les valeurs pour votre environnement.

# ============================================
# API Keys (OBLIGATOIRES)
# ============================================

# Google Gemini — Analyse et restauration d'images par IA
# Obtenez votre clé sur https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# D-ID — Animation faciale des photos restaurées
# Format: email:password (Basic Auth encodé en base64)
# Obtenez votre clé sur https://studio.d-id.com
DID_API_KEY=your-email:your-password

# ============================================
# Stripe — Paiements et abonnements (PRODUCTION)
# ============================================
# Obtenez vos clés sur https://dashboard.stripe.com/apikeys
# Prix créés le 14/05/2026 pour le compte acct_1TWkKwACw2Aur8P6
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Abonnements (récurrents)
STRIPE_PRICE_DECOUVERTE=price_1TWv9LACw2Aur8P6355PTFu5  # 4.99€/mois
STRIPE_PRICE_PREMIUM=price_1TWv9LACw2Aur8P6G0cMNlzR      # 29€/mois
STRIPE_PRICE_ANNUEL=price_1TXN2xACw2Aur8P6pJDhvsoV      # 232€/an (4 mois offerts)
# Packs crédits (one-time)
STRIPE_PRICE_CREDITS_30=price_1TWv5GACw2Aur8P6BbNsAPfo   # 9.90€
STRIPE_PRICE_CREDITS_50=price_1TWv5GACw2Aur8P6rpIaRdBM   # 14.90€
STRIPE_PRICE_CREDITS_110=price_1TWv5GACw2Aur8P6QPA4jLDC   # 24.90€
# Webhook: https://flashback-restore.com/api/stripe/webhook

# ============================================
# Clerk — Authentification utilisateurs
# ============================================
# Configurez sur https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_live_...
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# ============================================
# Base de données
# ============================================
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://flashback:flashback@localhost:5432/flashback?ssl=disable
# SQLite (développement local uniquement)
# DATABASE_URL=sqlite+aiosqlite:///./flashback.db

# ============================================
# Redis — Queue de tâches (ARQ) + Rate Limiter
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Backblaze B2 — Stockage objet (photos/vidéos)
# ============================================
# 1. Créez un bucket sur https://secure.backblaze.com/b2_buckets.htm
# 2. Générez une clé d'application avec accès au bucket
# 3. Copiez l'Endpoint S3 dans l'interface B2
B2_ENDPOINT=s3.eu-central-003.backblazeb2.com
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=flashback-restore
B2_REGION=eu-central-003
# Optionnel : URL CDN Cloudflare pour bande passante gratuite
# B2_CDN_URL=https://cdn.votre-domaine.com

# ============================================
# Email — SMTP (envoi de notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Flashback Restore <your-email@gmail.com>
SITE_URL=https://flashback-restore.com

# ============================================
# Application
# ============================================
ENVIRONMENT=production
LOG_LEVEL=info
SECRET_KEY=change-me-to-a-random-64-char-string

# ============================================
# URLs publiques
# ============================================
PUBLIC_BACKEND_URL=https://flashback-restore.com
ALLOWED_ORIGINS=https://flashback-restore.com,https://www.flashback-restore.com
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Clés API internes
# ============================================
ADMIN_API_KEY=your-admin-api-key
INTERNAL_API_KEY=your-internal-api-key

# ============================================
# Sentry — Monitoring d'erreurs (optionnel)
# ============================================
SENTRY_DSN=

# ============================================
# NextAuth OAuth (optionnel — Clerk est prioritaire)
# ============================================
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_FACEBOOK_ID=your-facebook-app-id
AUTH_FACEBOOK_SECRET=your-facebook-app-secret
AUTH_SECRET=your-auth-secret
