[Unit]
Description=Flashback ARQ Worker
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=flashback
WorkingDirectory=/opt/flashback-restore-monorepo/backend
Environment="ENVIRONMENT=production"
Environment="CLERK_SECRET_KEY=sk_test_NVaHy5Dm9iS9dCfn6Fxv2MZxR8aTu0LhNeaxKAyC70"
ExecStart=/opt/flashback-restore-monorepo/backend/.venv/bin/arq app.worker.WorkerSettings
Restart=always
RestartSec=5
TimeoutStopSec=30
StartLimitBurst=3
StartLimitIntervalSec=60
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
