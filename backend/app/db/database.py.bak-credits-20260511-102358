    Returns:
        L'ID de l'entrée d'audit créée.
    """
    audit_id = str(uuid.uuid4())
    maintenant = datetime.now(timezone.utc).isoformat()
    conn = _obtenir_connexion()
    try:
        conn.execute(
            """INSERT INTO audit_logs (id, evenement, email, utilisateur_id, ip, user_agent, reussite, detail, cree_le)
               VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)""",
            (audit_id, evenement, email, utilisateur_id, ip, user_agent, 1 if reussite else 0, detail, maintenant),
        )
        conn.commit()
        return audit_id
    finally:
        conn.close()


def lister_audit_logs(
    email: Optional[str] = None,
    evenement: Optional[str] = None,
    reussite: Optional[bool] = None,
    limite: int = 100,
    offset: int = 0,
) -> list[dict]:
    """
    Liste les logs d'audit avec filtres optionnels.

    Args:
        email: Filtrer par email.
        evenement: Filtrer par type d'événement.
        reussite: True = succès, False = échecs, None = tous.
        limite: Nombre max de résultats.
        offset: Décalage pour pagination.

    Returns:
        Liste de dictionnaires représentant les logs.
    """
    conn = _obtenir_connexion()
    try:
        conditions = []
        params = []
        if email:
            conditions.append("email = ?")
            params.append(email)
        if evenement:
            conditions.append("evenement = ?")
            params.append(evenement)
        if reussite is not None:
            conditions.append("reussite = ?")
            params.append(1 if reussite else 0)

        where = f"WHERE {' AND '.join(conditions)}" if conditions else ""
        query = f"SELECT * FROM audit_logs {where} ORDER BY cree_le DESC LIMIT ? OFFSET ?"
        params.extend([limite, offset])

        rows = conn.execute(query, params).fetchall()
        return [dict(row) for row in rows]
    finally:
        conn.close()


def compter_audit_logs(
    email: Optional[str] = None,
    evenement: Optional[str] = None,
    reussite: Optional[bool] = None,
) -> int:
    """Compte le nombre de logs d'audit correspondant aux filtres."""
    conn = _obtenir_connexion()
    try:
        conditions = []
        params = []
        if email:
            conditions.append("email = ?")
            params.append(email)
        if evenement:
            conditions.append("evenement = ?")
            params.append(evenement)
        if reussite is not None:
            conditions.append("reussite = ?")
            params.append(1 if reussite else 0)

        where = f"WHERE {' AND '.join(conditions)}" if conditions else ""
        row = conn.execute(f"SELECT COUNT(*) FROM audit_logs {where}", params).fetchone()
        return row[0] if row else 0
    finally:
        conn.close()
