def creer_token_reinitialisation(utilisateur_id: str, token: str, duree_minutes: int = 30) -> str:
    """Crée un token de réinitialisation de mot de passe. Retourne l'ID."""
    import uuid
    maintenant = datetime.now(timezone.utc)
    expire = maintenant + timedelta(minutes=duree_minutes)
    token_id = str(uuid.uuid4())
    conn = _obtenir_connexion()
    try:
        conn.execute(
            """INSERT INTO reinitialisation_mdp (id, utilisateur_id, token, expire_le, cree_le)
               VALUES (?, ?, ?, ?, ?)""",
            (token_id, utilisateur_id, token, expire.isoformat(), maintenant.isoformat()),
        )
        conn.commit()
        return token_id
    finally:
        conn.close()


def verifier_token_reinitialisation(token: str) -> Optional[dict]:
    """Vérifie un token de réinitialisation. Retourne l'entrée si valide, None sinon."""
    conn = _obtenir_connexion()
    try:
        row = conn.execute(
            "SELECT * FROM reinitialisation_mdp WHERE token = ? AND utilise = 0",
            (token,),
        ).fetchone()
        if not row:
            return None
        entry = dict(row)
        # Vérifier expiration
        expire = datetime.fromisoformat(entry["expire_le"])
        if datetime.now(timezone.utc) > expire:
            return None
        return entry
    finally:
        conn.close()


def marquer_token_utilise(token: str) -> bool:
    """Marque un token comme utilisé."""
    conn = _obtenir_connexion()
    try:
        cur = conn.execute(
            "UPDATE reinitialisation_mdp SET utilise = 1 WHERE token = ?",
            (token,),
        )
        conn.commit()
        return cur.rowcount > 0
    finally:
        conn.close()


