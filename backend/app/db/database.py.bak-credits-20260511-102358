def _migrer_base(conn: sqlite3.Connection) -> None:
    """Applique les migrations nécessaires aux bases existantes."""
    # Vérifier si la colonne derniere_attribution_credits existe
    cur = conn.execute("PRAGMA table_info(abonnements)")
    colonnes = [row[1] for row in cur.fetchall()]
    if "derniere_attribution_credits" not in colonnes:
        conn.execute(
            "ALTER TABLE abonnements ADD COLUMN derniere_attribution_credits TEXT"
        )
        conn.commit()

    # Vérifier si la colonne utilisateur_id existe dans travaux
    cur = conn.execute("PRAGMA table_info(travaux)")
    colonnes_travaux = [row[1] for row in cur.fetchall()]
    if "utilisateur_id" not in colonnes_travaux:
        conn.execute(
            "ALTER TABLE travaux ADD COLUMN utilisateur_id TEXT REFERENCES utilisateurs(id)"
        )
        conn.execute(
            "CREATE INDEX IF NOT EXISTS idx_travaux_utilisateur ON travaux(utilisateur_id)"
        )
        conn.commit()

    # Vérifier si les colonnes OAuth existent dans utilisateurs
    cur = conn.execute("PRAGMA table_info(utilisateurs)")
    colonnes_users = [row[1] for row in cur.fetchall()]
    if "oauth_provider" not in colonnes_users:
        conn.execute("ALTER TABLE utilisateurs ADD COLUMN oauth_provider TEXT")
        conn.execute("ALTER TABLE utilisateurs ADD COLUMN oauth_provider_id TEXT")
        conn.execute("CREATE INDEX IF NOT EXISTS idx_oauth_provider ON utilisateurs(oauth_provider, oauth_provider_id)")
        conn.commit()
    # Migration Plan/Animation (rapport COGS 10/05/2026)
    if "plan" not in colonnes_users:
        conn.execute("ALTER TABLE utilisateurs ADD COLUMN plan TEXT DEFAULT 'gratuit'")
        conn.execute("ALTER TABLE utilisateurs ADD COLUMN animations_utilisees INTEGER DEFAULT 0")
        conn.execute("ALTER TABLE utilisateurs ADD COLUMN mois_animation_courant TEXT")
        conn.commit()


