# =============================================================
# Flashback Restore — Variables d'environnement
# =============================================================
# Copiez ce fichier en .env et remplissez les valeurs.
#   cp .env.example .env
#
# ⚠️  Ne commitez JAMAIS le fichier .env (il est dans .gitignore).

# --- Google Gemini ---
# Clé API Gemini pour l'analyse et la restauration de photos.
# Obtenez-la sur : https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyC33Y8WS6_voVPaMY2RCIsy_35bkxdsV-w
# Modèle à utiliser (gemini-2.5-flash recommandé pour la vision)
GEMINI_MODEL=gemini-2.5-flash

# --- D-ID (animation de portraits) ---
# ⚠️  PLACEHOLDER — Remplacez par votre vraie clé API D-ID
# Obtenez-la sur : https://studio.d-id.com/
DID_API_KEY=DID_API_KEY_PLACEHOLDER
# URL de base de l'API D-ID
DID_BASE_URL=https://api.d-id.com

# --- Serveur ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
