# ============================================
# Flashback Restore — .env.example
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# --- API Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- API D-ID (animation) ---
DID_API_KEY=your_did_api_key_here
DID_BASE_URL=https://api.d-id.com

# --- Base de données ---
DATABASE_URL=postgresql+asyncpg://flashback:CHANGE_ME@localhost:5432/flashback

# --- Sécurité ---
SECRET_KEY=generate_a_random_64_char_hex_string_here
AUTH_SECRET=generate_a_random_32_char_base64_string_here
INTERNAL_API_KEY=generate_a_random_64_char_hex_string_here
ADMIN_API_KEY=generate_a_random_32_char_hex_string_here

# --- Stripe (paiements) ---
STRIPE_API_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_DECOUVERTE=price_decouverte_monthly
STRIPE_PRICE_PREMIUM=price_premium_monthly
STRIPE_PRICE_ANNUEL=price_premium_yearly
STRIPE_PRICE_CREDITS_30=price_credits_30
STRIPE_PRICE_CREDITS_50=price_credits_50
STRIPE_PRICE_CREDITS_110=price_credits_110

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com

# --- URLs publiques ---
PUBLIC_BACKEND_URL=http://localhost:8000
SITE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Serveur ---
HOST=127.0.0.1
PORT=8000
DEBUG=false
ENVIRONMENT=development
